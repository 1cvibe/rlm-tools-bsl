# Required for llm_query() / llm_query_batched() sub-LLM features
# Optional — server works without it, just no LLM query capability
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the sub-LLM model (default: claude-haiku-4-5-20251001)
# RLM_SUB_MODEL=claude-haiku-4-5-20251001

# Optional: max concurrent sessions (default: 5)
# RLM_MAX_SESSIONS=5

# Optional: session inactivity timeout in minutes (default: 10)
# RLM_SESSION_TIMEOUT=10
